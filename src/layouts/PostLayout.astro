---
import BaseLayout from './BaseLayout.astro';
import type { Lang } from '../i18n/strings';
import { tr, langPath } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  date?: Date;
  current?: string;
  backTo?: string;
}
const { title, description, lang, date, current, backTo } = Astro.props;
const fmt = new Intl.DateTimeFormat(lang === 'zh' ? 'zh-CN' : 'en-US', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---
<BaseLayout title={title} description={description} lang={lang} current={current}>
  {backTo && (
    <a href={langPath(lang, backTo)} class="text-sm text-ink-soft border-0 hover:text-ink">
      {tr('back', lang)}
    </a>
  )}
  <article class="mt-4">
    <header class="mb-8">
      <h1 class="font-serif text-3xl md:text-[2rem] leading-tight tracking-tight text-ink">
        {title}
      </h1>
      {date && (
        <div class="mt-2 text-sm text-ink-soft">{fmt.format(date)}</div>
      )}
    </header>
    <div class="prose prose-neutral max-w-none">
      <slot />
    </div>
  </article>
</BaseLayout>
