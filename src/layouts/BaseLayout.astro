---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  current?: string;
}
const { title, description, lang, current } = Astro.props;
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Header lang={lang} current={current} />
    <main class="flex-1 w-full">
      <div class="mx-auto max-w-[var(--page-max)] px-5 py-10 md:py-14">
        <slot />
      </div>
    </main>
    <Footer lang={lang} />
    <script is:inline>
      // WeChat in-app browser autoplay shim:
      // muted+autoplay+playsinline covers most cases, but many WeChat builds
      // still gate autoplay on a user gesture. We retry .play() on every
      // signal we can hook into: JSBridge ready, first touch/scroll/click,
      // visibility change, and when a video scrolls into view.
      (function () {
        function tryPlay(v) {
          if (!v) return;
          try {
            v.muted = true; // belt and suspenders
            var p = v.play();
            if (p && typeof p.catch === 'function') p.catch(function () {});
          } catch (_) {}
        }
        function playAll() {
          document.querySelectorAll('video[autoplay]').forEach(tryPlay);
        }
        // 1) WeixinJSBridge: fires once when the in-app bridge is ready.
        if (typeof window.WeixinJSBridge !== 'undefined') {
          playAll();
        } else {
          document.addEventListener('WeixinJSBridgeReady', playAll, false);
        }
        // 2) First user gesture — most reliable trigger across all browsers.
        ['touchstart', 'touchend', 'click', 'scroll'].forEach(function (ev) {
          window.addEventListener(ev, playAll, { once: true, passive: true, capture: true });
        });
        // 3) Visibility regained (e.g. came back from another tab/app).
        document.addEventListener('visibilitychange', function () {
          if (!document.hidden) playAll();
        });
        // 4) Per-video: retry when each enters the viewport.
        function attachObserver() {
          if (!('IntersectionObserver' in window)) return;
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) { if (e.isIntersecting) tryPlay(e.target); });
          }, { threshold: 0.1 });
          document.querySelectorAll('video[autoplay]').forEach(function (v) { io.observe(v); });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attachObserver);
        } else {
          attachObserver();
        }
      })();
    </script>
  </body>
</html>
