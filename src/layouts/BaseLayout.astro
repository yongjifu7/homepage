---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import type { Lang } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  current?: string;
}
const { title, description, lang, current } = Astro.props;
---
<!doctype html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://rsms.me/" />
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <Header lang={lang} current={current} />
    <main class="flex-1 w-full">
      <div class="mx-auto max-w-[var(--page-max)] px-5 py-10 md:py-14">
        <slot />
      </div>
    </main>
    <Footer lang={lang} />
    <script is:inline>
      // WeChat in-app browser autoplay shim:
      // muted+autoplay+playsinline covers most cases, but some WeChat builds
      // still hold off until the JSBridge is ready. Re-issue play() then.
      (function () {
        function playAll() {
          document.querySelectorAll('video[autoplay]').forEach(function (v) {
            var p = v.play();
            if (p && typeof p.catch === 'function') p.catch(function () {});
          });
        }
        if (typeof window.WeixinJSBridge !== 'undefined') {
          playAll();
        } else {
          document.addEventListener('WeixinJSBridgeReady', playAll, false);
        }
        // Also retry once on visibility (helps when video was paused on cellular).
        document.addEventListener('visibilitychange', function () {
          if (!document.hidden) playAll();
        });
      })();
    </script>
  </body>
</html>
