---
import type { CollectionEntry } from 'astro:content';
import type { Lang } from '../i18n/strings';
import { tr, langPath } from '../i18n/strings';
import { renderMarkdown } from '../utils/renderMarkdown';

interface Props {
  entry: CollectionEntry<'publications'>;
  lang: Lang;
}
const { entry, lang } = Astro.props;
const d = entry.data;
const title = lang === 'zh' && d.title_zh ? d.title_zh : d.title;
const venue = lang === 'zh' && d.venue_zh ? d.venue_zh : d.venue;

function renderAuthors(authors: string[]): string {
  return authors
    .map((a) =>
      /Yongji Fu|Fu,\s*Y\.|符永骥/.test(a)
        ? `<span class="author-me">${a}</span>`
        : a
    )
    .join(', ');
}

const statusLabel =
  d.status === 'under-review'
    ? lang === 'zh' ? '审稿中' : 'Under review'
    : d.status === 'preprint'
    ? 'Preprint'
    : d.status === 'in-preparation'
    ? lang === 'zh' ? '撰写中' : 'In preparation'
    : null;

const abstractSource =
  lang === 'zh'
    ? d.abstract_zh ?? d.abstract_en
    : d.abstract_en ?? d.abstract_zh;
const abstractHtml = await renderMarkdown(abstractSource);
const hasAbstract = abstractHtml.length > 0;

const thumb = d.thumbnail;
const isVideo = !!thumb && /\.(mp4|webm|mov)$/i.test(thumb);
const poster = isVideo && thumb ? thumb.replace(/\.(mp4|webm|mov)$/i, '.jpg') : undefined;
const detailHref = langPath(lang, `publications/${entry.id}`);
---
<article class="pub-entry group py-5">
  <div class="pub-grid">
    <div class="pub-media">
      {thumb && isVideo && (
        <video
          class="pub-media-el"
          src={thumb}
          poster={poster}
          autoplay
          muted
          loop
          playsinline
          webkit-playsinline="true"
          x5-playsinline="true"
          x5-video-player-type="h5-page"
          x5-video-player-fullscreen="false"
          preload="metadata"
        />
      )}
      {thumb && !isVideo && (
        <img class="pub-media-el" src={thumb} alt={title} loading="lazy" />
      )}
    </div>
    <div class="pub-body">
      <h3 class="pub-title">
        <a href={detailHref} class="pub-title-link">{title}</a>
      </h3>
      <p class="pub-authors" set:html={renderAuthors(d.authors)} />
      <p class="pub-venue">
        <em>{venue}</em>{statusLabel ? <span>, {statusLabel}</span> : ''}, {d.year}
      </p>
      <p class="pub-links">
        {[
          d.webpage && { label: tr('webpage', lang), href: d.webpage, external: true },
          d.pdf && { label: tr('pdf', lang), href: d.pdf, external: true },
          hasAbstract && { label: tr('abstract', lang), href: `#abstract-${entry.id}`, abstract: true },
          d.bibtex && { label: tr('bibtex', lang), href: `#bibtex-${entry.id}`, bibtex: true },
          d.arxiv && { label: tr('arxiv', lang), href: `https://arxiv.org/abs/${d.arxiv}`, external: true },
          d.code && { label: tr('code_link', lang), href: d.code, external: true },
        ]
          .filter(Boolean)
          .map((link: any, i, arr) => (
            <>
              <a
                href={link.href}
                class="pub-link"
                data-toggle={link.abstract ? `abstract-${entry.id}` : link.bibtex ? `bibtex-${entry.id}` : null}
                target={link.external ? '_blank' : undefined}
                rel={link.external ? 'noopener' : undefined}
              >{link.label}</a>
              {i < arr.length - 1 && <span class="pub-sep">·</span>}
            </>
          ))}
      </p>
    </div>
  </div>
  {hasAbstract && (
    <div id={`abstract-${entry.id}`} class="pub-collapsible hidden">
      <div class="abstract-body" set:html={abstractHtml} />
    </div>
  )}
  {d.bibtex && (
    <pre id={`bibtex-${entry.id}`} class="pub-bibtex hidden">{d.bibtex}</pre>
  )}
</article>

<style>
  .pub-entry { position: relative; }
  .pub-grid {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 1.25rem;
    align-items: start;
  }
  @media (max-width: 640px) {
    .pub-grid { grid-template-columns: 1fr; gap: 0.75rem; }
  }
  .pub-media {
    width: 100%;
    aspect-ratio: 16 / 10;
    background: #f3f3f2;
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pub-media:empty {
    /* Keep the column alignment even when no thumbnail is provided.
       Use a subtle no-media pattern so the slot doesn't look accidental. */
    background: transparent;
    border: 1px dashed #ebebe9;
  }
  .pub-media-el {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .pub-body { min-width: 0; }
  .pub-title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 1.15rem;
    line-height: 1.35;
    letter-spacing: -0.005em;
    color: #0a0a0a;
    margin: 0;
  }
  .pub-title-link {
    color: inherit;
    border-bottom: 0;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 0.2s ease, color 0.2s ease;
  }
  .pub-title-link:hover {
    background-size: 100% 1px;
    color: #0a66c2;
    opacity: 1;
  }
  .pub-authors {
    margin-top: 0.4rem;
    font-size: 0.925rem;
    line-height: 1.55;
    color: #4a4a4a;
  }
  .pub-authors :global(.author-me) {
    color: #0a0a0a;
    font-weight: 600;
    border-bottom: 1.5px dotted #b3b3b3;
  }
  .pub-venue {
    margin-top: 0.2rem;
    font-size: 0.875rem;
    color: #6b6b6b;
  }
  .pub-venue em { font-style: italic; }
  .pub-links {
    margin-top: 0.6rem;
    font-size: 0.825rem;
    color: #6b6b6b;
    display: flex;
    flex-wrap: wrap;
    gap: 0.2rem 0.35rem;
    align-items: center;
    font-feature-settings: 'tnum';
  }
  .pub-link {
    color: #4a4a4a;
    border-bottom: 0;
    padding: 0.1rem 0.35rem;
    border-radius: 3px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .pub-link:hover {
    background: #0a0a0a;
    color: #fff;
    opacity: 1;
  }
  .pub-sep { color: #c5c5c5; }
  .pub-collapsible {
    margin-top: 0.9rem;
    padding: 1rem 1.25rem;
    background: #f8f8f7;
    border-left: 2px solid #c5c5c5;
    border-radius: 0 4px 4px 0;
  }
  .abstract-body :global(p) {
    margin: 0 0 0.7em 0;
    font-size: 0.92rem;
    line-height: 1.75;
    color: #2a2a2a;
  }
  .abstract-body :global(p:last-child) { margin-bottom: 0; }
  .abstract-body :global(strong) { color: #0a0a0a; }
  .pub-bibtex {
    margin-top: 0.8rem;
    padding: 0.9rem 1.1rem;
    background: #0d1117;
    color: #e5e7eb;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.6;
    border-radius: 6px;
    overflow-x: auto;
  }
</style>

<script>
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const key = target?.dataset?.toggle;
    if (!key) return;
    e.preventDefault();
    const el = document.getElementById(key);
    if (el) el.classList.toggle('hidden');
  });
</script>
