---
import { type Lang, tr, otherLang, langPath } from '../i18n/strings';

interface Props {
  lang: Lang;
  current?: string;
}
const { lang, current } = Astro.props;

const items = [
  { key: 'nav_home', path: '' },
  { key: 'nav_about', path: 'about' },
  { key: 'nav_publications', path: 'publications' },
  { key: 'nav_projects', path: 'projects' },
  { key: 'nav_blog', path: 'blog' },
] as const;

const other = otherLang(lang);
const otherUrl = langPath(other, current || '');
---
<header class="site-header">
  <div class="site-header-inner">
    <a href={langPath(lang)} class="brand">
      {lang === 'en' ? 'Yongji Fu' : '符永骥'}
    </a>
    <nav class="nav">
      {items.map(({ key, path }) => {
        const href = langPath(lang, path);
        const active = current === path;
        return (
          <a href={href} class:list={['nav-link', active && 'nav-link-active']}>
            {tr(key, lang)}
          </a>
        );
      })}
      <a href={otherUrl} class="lang-toggle">{tr('lang_switch', lang)}</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--rule);
    background: rgba(255, 255, 255, 0.85);
    backdrop-filter: saturate(180%) blur(8px);
    -webkit-backdrop-filter: saturate(180%) blur(8px);
    position: sticky;
    top: 0;
    z-index: 20;
  }
  .site-header-inner {
    max-width: var(--page-max);
    margin: 0 auto;
    padding: 1.1rem 1.25rem;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    letter-spacing: -0.005em;
    color: var(--ink);
    border-bottom: 0;
  }
  .brand:hover { opacity: 0.7; }
  .nav {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    font-size: 0.875rem;
    color: var(--ink-muted);
    flex-wrap: wrap;
  }
  .nav-link {
    color: var(--ink-muted);
    border-bottom: 0;
    padding: 0.25rem 0;
    position: relative;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 1px;
    background: var(--ink);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.2s ease;
  }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link:hover { color: var(--ink); opacity: 1; }
  .nav-link-active { color: var(--ink); font-weight: 500; }
  .nav-link-active::after { transform: scaleX(1); }
  .lang-toggle {
    color: var(--ink-soft);
    border-bottom: 0;
    margin-left: 0.5rem;
    font-size: 0.82rem;
  }
  .lang-toggle:hover { color: var(--ink); opacity: 1; }
</style>
