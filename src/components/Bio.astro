---
interface Props {
  lang: 'en' | 'zh';
  variant: 'hero' | 'prose';
}
const { lang, variant } = Astro.props;

const BIO = {
  en: {
    intro_html:
      `I am <strong>Yongji Fu</strong> (符永骥), an MSc student in Robotics Engineering at the <strong>University of Bristol</strong> (2025.09 – 2026.10), advised by <a href="https://lepora.com/" target="_blank" rel="noopener">Nathan F. Lepora</a> and <a href="https://guan1206.github.io/" target="_blank" rel="noopener">Guanqun Cao</a>. Before Bristol I received my BSc in Information Management and Information Systems from <strong>Chongqing University of Posts and Telecommunications</strong>.`,
    goal_label: 'Goal',
    goal_html:
      `To build robotic and agentic systems that <em>continuously learn</em> and <em>iteratively self-improve</em> through interaction with the physical world.`,
    ri_label_hero: 'Research Interests',
    ri_label_prose: 'Research Interests',
    ri_html:
      `large-scale machine learning · world model for robot learning · continuous self-evolving agent · general-purpose loco-manipulation`,
  },
  zh: {
    intro_html:
      `我是<strong>符永骥</strong>（Yongji Fu），目前在<strong>布里斯托大学</strong>攻读机器人工程硕士（2025.09 – 2026.10），导师为 <a href="https://lepora.com/" target="_blank" rel="noopener">Nathan F. Lepora</a> 与 <a href="https://guan1206.github.io/" target="_blank" rel="noopener">Guanqun Cao</a>。本科毕业于<strong>重庆邮电大学</strong>信息管理与信息系统专业。`,
    goal_label: 'Goal',
    goal_html:
      `建立可以<em>持续学习</em>、<em>自我迭代</em>的机器人或 Agent 系统，让它们在与物理世界的持续交互中不断成长。`,
    ri_label_hero: 'Research Interests',
    ri_label_prose: '研究兴趣',
    ri_html:
      `大规模机器学习 · 面向机器人学习的世界模型 · 持续自进化 Agent · 通用移动操作（loco-manipulation）`,
  },
};
const b = BIO[lang];
---
{variant === 'hero' ? (
  <>
    <div class="hero-intro">
      <p set:html={b.intro_html}></p>
    </div>
    <div class="hero-focus">
      <p>
        <span class="focus-label">{b.goal_label}</span> &nbsp;
        <Fragment set:html={b.goal_html} />
      </p>
      <p>
        <span class="focus-label">{b.ri_label_hero}</span> &nbsp;
        <Fragment set:html={b.ri_html} />
      </p>
    </div>
  </>
) : (
  <>
    <p set:html={b.intro_html}></p>
    <h2>{b.goal_label}</h2>
    <p set:html={b.goal_html}></p>
    <h2>{b.ri_label_prose}</h2>
    <p set:html={b.ri_html}></p>
  </>
)}

<style>
  .hero-intro {
    margin-top: 0.85rem;
    max-width: 64ch;
  }
  .hero-intro p {
    font-size: 0.98rem;
    line-height: 1.7;
    color: var(--ink-muted);
    margin: 0;
  }
  .hero-intro :global(strong) { color: var(--ink); font-weight: 600; }
  .hero-intro :global(a) {
    color: var(--ink);
    border-bottom: 1px solid #d4d4d4;
    font-weight: 500;
  }
  .hero-intro :global(a:hover) { border-bottom-color: var(--ink); opacity: 1; }

  .hero-focus {
    margin-top: 0.9rem;
    padding: 0.7rem 0.95rem;
    border-left: 2px solid #d4d4d4;
    background: #fafaf9;
    border-radius: 0 4px 4px 0;
    max-width: 64ch;
  }
  .hero-focus p {
    font-size: 0.92rem;
    line-height: 1.65;
    color: var(--ink-muted);
    margin: 0 0 0.35rem 0;
  }
  .hero-focus p:last-child { margin-bottom: 0; }
  .focus-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 600;
  }
</style>
