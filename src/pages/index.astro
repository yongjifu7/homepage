---
import BaseLayout from '../layouts/BaseLayout.astro';
import PubEntry from '../components/PubEntry.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionHeader from '../components/SectionHeader.astro';
import Bio from '../components/Bio.astro';
import { getCollection } from 'astro:content';
import { tr, langPath } from '../i18n/strings';

const lang = 'en' as const;
const pubs = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 5);
const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const posts = (await getCollection('blog', (e) => !e.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const fmt = new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout title="Yongji Fu" description="Personal website of Yongji Fu — MSc Robotics Engineering, University of Bristol" lang={lang} current="">
  <section class="hero">
    <img src="/images/avatar.jpg" alt="Yongji Fu" class="hero-avatar" />
    <div class="hero-body">
      <h1 class="hero-name">
        Yongji Fu
        <span class="hero-name-zh">符永骥</span>
      </h1>
      <Bio lang="en" variant="hero" />
      <p class="hero-links">
        <a href="mailto:yongji.fu7@gmail.com">yongji.fu7@gmail.com</a>
        <span class="dot">·</span>
        <a href="https://github.com/yongjifu7" target="_blank" rel="noopener">GitHub</a>
        <span class="dot">·</span>
        <a href={langPath(lang, 'about')}>About</a>
      </p>
    </div>
  </section>

  <section class="home-section">
    <SectionHeader
      title={tr('nav_publications', lang)}
      href={langPath(lang, 'publications')}
      linkLabel={tr('all_pub', lang)}
    />
    <div class="pub-list">
      {pubs.map((p) => <PubEntry entry={p} lang={lang} />)}
    </div>
  </section>

  <section class="home-section">
    <SectionHeader
      title={tr('nav_projects', lang)}
      href={langPath(lang, 'projects')}
      linkLabel={tr('all_projects', lang)}
    />
    <div class="project-list">
      {projects.map((p) => <ProjectCard entry={p} lang={lang} />)}
    </div>
  </section>

  <section class="home-section">
    <SectionHeader
      title={tr('nav_blog', lang)}
      href={langPath(lang, 'blog')}
      linkLabel={tr('all_blog', lang)}
    />
    <ul class="blog-list">
      {posts.map((p) => (
        <li>
          <time>{fmt.format(p.data.date)}</time>
          <a href={langPath(lang, `blog/${p.id}`)}>{p.data.title}</a>
        </li>
      ))}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.4rem;
    padding-bottom: 0.5rem;
  }
  @media (min-width: 640px) {
    .hero { flex-direction: row; align-items: flex-start; gap: 2.25rem; padding-top: 0.25rem; }
  }
  .hero-avatar {
    width: 7rem;
    height: 7rem;
    border-radius: 9999px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 1px 0 rgba(0,0,0,0.05), 0 0 0 1px rgba(0,0,0,0.04);
  }
  @media (min-width: 640px) {
    .hero-avatar { width: 8.5rem; height: 8.5rem; }
  }
  .hero-body { flex: 1; min-width: 0; }
  .hero-name {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0;
  }
  @media (min-width: 640px) {
    .hero-name { font-size: 2.3rem; }
  }
  .hero-name-zh {
    display: inline-block;
    margin-left: 0.6rem;
    color: var(--ink-soft);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0;
    vertical-align: middle;
  }
  .hero-links {
    margin-top: 0.4rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
  .hero-links a {
    color: var(--ink-muted);
    border-bottom: 1px solid #e0e0e0;
  }
  .hero-links a:hover {
    color: var(--ink);
    border-bottom-color: var(--ink);
    opacity: 1;
  }
  .hero-links .dot { margin: 0 0.4rem; color: #c9c9c9; }

  .home-section { margin-top: 3.5rem; }
  .pub-list > :global(article) { border-bottom: 1px solid #f0f0f0; }
  .pub-list > :global(article:last-child) { border-bottom: 0; }

  .blog-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .blog-list li {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    padding: 0.55rem 0;
    border-bottom: 1px solid #f3f3f2;
  }
  .blog-list li:last-child { border-bottom: 0; }
  .blog-list time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-soft);
    width: 6.5rem;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .blog-list a {
    font-family: var(--font-serif);
    font-size: 1.02rem;
    color: var(--ink);
    border-bottom: 0;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 0.2s ease, color 0.2s ease;
  }
  .blog-list a:hover {
    background-size: 100% 1px;
    color: var(--accent);
    opacity: 1;
  }
</style>
