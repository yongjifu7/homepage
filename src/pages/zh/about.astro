---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getEntry, render } from 'astro:content';

const lang = 'zh' as const;
const entry = await getEntry('about', 'zh');
if (!entry) throw new Error('Missing content/about/zh.md');
const { Content } = await render(entry);
---
<BaseLayout title={`${entry.data.title} — 符永骥`} description="符永骥的个人介绍" lang={lang} current="about">
  <h1 class="page-title">{entry.data.title}</h1>
  <div class="prose prose-neutral max-w-none mt-6">
    <Content />
  </div>
</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0;
  }
</style>
