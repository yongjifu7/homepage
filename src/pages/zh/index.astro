---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PubEntry from '../../components/PubEntry.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import SectionHeader from '../../components/SectionHeader.astro';
import { getCollection } from 'astro:content';
import { tr, langPath } from '../../i18n/strings';

const lang = 'zh' as const;
const pubs = (await getCollection('publications'))
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 5);
const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const posts = (await getCollection('blog', (e) => !e.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const fmt = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="符永骥 · Yongji Fu" description="符永骥的个人主页 — 布里斯托大学机器人工程硕士" lang={lang} current="">
  <section class="hero">
    <img src="/images/avatar.jpg" alt="符永骥" class="hero-avatar" />
    <div class="hero-body">
      <h1 class="hero-name">
        符永骥
        <span class="hero-name-zh">Yongji Fu</span>
      </h1>
      <div class="hero-intro">
        <p>
          我目前在<strong>布里斯托大学</strong>攻读机器人工程硕士，导师为
          <a href="https://www.kcl.ac.uk/people/shan-luo" target="_blank" rel="noopener">Shan Luo</a>
          （King's College London）与
          <a href="https://guan1206.github.io/" target="_blank" rel="noopener">Guanqun Cao</a>。
          我的研究关注机器人学习、多模态感知与大规模优化三者的交叉。
        </p>
        <p>
          本科毕业于<strong>重庆邮电大学</strong>信息管理与信息系统专业，
          师从王永老师与黄东斌老师，从事组合优化与深度学习在工业系统中的落地研究。
        </p>
      </div>
      <div class="hero-focus">
        <p>
          <span class="focus-label">Goal</span> &nbsp;
          构建能够在与物理世界的持续交互中 <em>不断学习、自我迭代</em> 的机器人与智能体系统。
        </p>
        <p>
          <span class="focus-label">Research Interests</span> &nbsp;
          大规模机器学习 · world &amp; action models · agentic systems ·
          通用化 loco-manipulation
        </p>
      </div>
      <p class="hero-links">
        <a href="mailto:yongji.fu7@gmail.com">yongji.fu7@gmail.com</a>
        <span class="dot">·</span>
        <a href="https://github.com/yongjifu7" target="_blank" rel="noopener">GitHub</a>
        <span class="dot">·</span>
        <a href={langPath(lang, 'about')}>关于我</a>
      </p>
    </div>
  </section>

  <section class="home-section">
    <SectionHeader
      title={tr('nav_publications', lang)}
      href={langPath(lang, 'publications')}
      linkLabel={tr('all_pub', lang)}
    />
    <div class="pub-list">
      {pubs.map((p) => <PubEntry entry={p} lang={lang} />)}
    </div>
  </section>

  <section class="home-section">
    <SectionHeader
      title={tr('nav_projects', lang)}
      href={langPath(lang, 'projects')}
      linkLabel={tr('all_projects', lang)}
    />
    <div class="project-list">
      {projects.map((p) => <ProjectCard entry={p} lang={lang} />)}
    </div>
  </section>

  <section class="home-section">
    <SectionHeader
      title={tr('nav_blog', lang)}
      href={langPath(lang, 'blog')}
      linkLabel={tr('all_blog', lang)}
    />
    <ul class="blog-list">
      {posts.map((p) => {
        const title = p.data.title_zh ?? p.data.title;
        return (
          <li>
            <time>{fmt.format(p.data.date)}</time>
            <a href={langPath(lang, `blog/${p.id}`)}>{title}</a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<style>
  .hero {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.4rem;
    padding-bottom: 0.5rem;
  }
  @media (min-width: 640px) {
    .hero { flex-direction: row; align-items: flex-start; gap: 2.25rem; padding-top: 0.25rem; }
  }
  .hero-avatar {
    width: 7rem;
    height: 7rem;
    border-radius: 9999px;
    object-fit: cover;
    flex-shrink: 0;
    box-shadow: 0 1px 0 rgba(0,0,0,0.05), 0 0 0 1px rgba(0,0,0,0.04);
  }
  @media (min-width: 640px) {
    .hero-avatar { width: 8.5rem; height: 8.5rem; }
  }
  .hero-body { flex: 1; min-width: 0; }
  .hero-name {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0;
  }
  @media (min-width: 640px) {
    .hero-name { font-size: 2.3rem; }
  }
  .hero-name-zh {
    display: inline-block;
    margin-left: 0.6rem;
    color: var(--ink-soft);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0;
    vertical-align: middle;
  }
  .hero-intro {
    margin-top: 0.85rem;
    max-width: 64ch;
  }
  .hero-intro p {
    font-size: 0.98rem;
    line-height: 1.85;
    color: var(--ink-muted);
    margin: 0 0 0.55rem 0;
  }
  .hero-intro p:last-child { margin-bottom: 0; }
  .hero-intro strong { color: var(--ink); font-weight: 600; }
  .hero-intro a {
    color: var(--ink);
    border-bottom: 1px solid #d4d4d4;
    font-weight: 500;
  }
  .hero-intro a:hover { border-bottom-color: var(--ink); opacity: 1; }

  .hero-focus {
    margin-top: 0.9rem;
    padding: 0.7rem 0.95rem;
    border-left: 2px solid #d4d4d4;
    background: #fafaf9;
    border-radius: 0 4px 4px 0;
    max-width: 64ch;
  }
  .hero-focus p {
    font-size: 0.92rem;
    line-height: 1.7;
    color: var(--ink-muted);
    margin: 0 0 0.35rem 0;
  }
  .hero-focus p:last-child { margin-bottom: 0; }
  .focus-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink);
    font-weight: 600;
  }
  .hero-links { margin-top: 0.4rem; font-size: 0.85rem; color: var(--ink-soft); }
  .hero-links a { color: var(--ink-muted); border-bottom: 1px solid #e0e0e0; }
  .hero-links a:hover { color: var(--ink); border-bottom-color: var(--ink); opacity: 1; }
  .hero-links .dot { margin: 0 0.4rem; color: #c9c9c9; }

  .home-section { margin-top: 3.5rem; }
  .pub-list > :global(article) { border-bottom: 1px solid #f0f0f0; }
  .pub-list > :global(article:last-child) { border-bottom: 0; }

  .blog-list { list-style: none; margin: 0; padding: 0; }
  .blog-list li {
    display: flex;
    gap: 1rem;
    align-items: baseline;
    padding: 0.55rem 0;
    border-bottom: 1px solid #f3f3f2;
  }
  .blog-list li:last-child { border-bottom: 0; }
  .blog-list time {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--ink-soft);
    width: 7.5rem;
    flex-shrink: 0;
    font-variant-numeric: tabular-nums;
  }
  .blog-list a {
    font-family: var(--font-serif);
    font-size: 1.02rem;
    color: var(--ink);
    border-bottom: 0;
    background-image: linear-gradient(currentColor, currentColor);
    background-position: 0 100%;
    background-repeat: no-repeat;
    background-size: 0 1px;
    transition: background-size 0.2s ease, color 0.2s ease;
  }
  .blog-list a:hover { background-size: 100% 1px; color: var(--accent); opacity: 1; }
</style>
