---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PubEntry from '../../components/PubEntry.astro';
import { getCollection } from 'astro:content';
import { tr, langPath } from '../../i18n/strings';

const lang = 'zh' as const;
const pubs = (await getCollection('publications')).sort((a, b) => b.data.year - a.data.year).slice(0, 3);
const posts = (await getCollection('blog', (e) => !e.data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
const fmt = new Intl.DateTimeFormat('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BaseLayout title="符永骥 · Yongji Fu" description="符永骥的个人主页" lang={lang} current="">
  <section class="flex flex-col md:flex-row items-start gap-6 md:gap-10">
    <img src="/images/avatar.jpg" alt="符永骥" class="w-28 h-28 md:w-36 md:h-36 rounded-full object-cover flex-shrink-0" />
    <div class="flex-1">
      <h1 class="font-serif text-3xl md:text-[2.1rem] leading-tight tracking-tight">符永骥 <span class="text-ink-soft font-sans text-base">· Yongji Fu</span></h1>
      <p class="mt-3 text-ink-muted leading-relaxed">{tr('tagline', lang)}</p>
      <p class="mt-3 text-sm text-ink-soft">
        布里斯托大学 · 机器人工程硕士 ·
        <a href="mailto:yongji.fu7@gmail.com" class="border-0 underline decoration-gray-300">yongji.fu7@gmail.com</a>
      </p>
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-baseline justify-between">
      <h2 class="font-serif text-xl">{tr('recent_pub', lang)}</h2>
      <a href={langPath(lang, 'publications')} class="text-sm text-ink-soft border-0 hover:text-ink">{tr('all_pub', lang)} →</a>
    </div>
    <div class="mt-2 divide-y divide-gray-100">
      {pubs.map((p) => <PubEntry entry={p} lang={lang} />)}
    </div>
  </section>

  <section class="mt-12">
    <div class="flex items-baseline justify-between">
      <h2 class="font-serif text-xl">{tr('recent_blog', lang)}</h2>
      <a href={langPath(lang, 'blog')} class="text-sm text-ink-soft border-0 hover:text-ink">{tr('all_blog', lang)} →</a>
    </div>
    <ul class="mt-3 space-y-2">
      {posts.map((p) => {
        const title = p.data.title_zh ?? p.data.title;
        return (
          <li class="flex flex-col md:flex-row md:items-baseline md:gap-4">
            <time class="text-sm text-ink-soft font-mono shrink-0 md:w-28">{fmt.format(p.data.date)}</time>
            <a href={langPath(lang, `blog/${p.slug}`)} class="border-0 hover:opacity-70 text-ink">
              {title}
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>
