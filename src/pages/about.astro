---
import BaseLayout from '../layouts/BaseLayout.astro';
import Bio from '../components/Bio.astro';
import { getEntry, render } from 'astro:content';

const lang = 'en' as const;
const entry = await getEntry('about', 'en');
if (!entry) throw new Error('Missing content/about/en.md');
const { Content } = await render(entry);
---
<BaseLayout title={`${entry.data.title} — Yongji Fu`} description="About Yongji Fu" lang={lang} current="about">
  <h1 class="page-title">{entry.data.title}</h1>
  <div class="prose prose-neutral max-w-none mt-6">
    <Bio lang="en" variant="prose" />
    <Content />
  </div>
</BaseLayout>

<style>
  .page-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0;
  }
</style>
